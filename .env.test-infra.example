# Local test infrastructure defaults.
# Docker Compose reads this file only if passed explicitly:
# docker compose --env-file .env.test-infra.example -f docker-compose.test-infra.yml up -d

SUMMARY_TEST_CLICKHOUSE_USER=default
SUMMARY_TEST_CLICKHOUSE_PASSWORD=
SUMMARY_TEST_CLICKHOUSE_HTTP_PORT=8123
SUMMARY_TEST_CLICKHOUSE_NATIVE_PORT=9000

SUMMARY_TEST_REDIS_PORT=6379

# App-side values for future FastAPI/Dramatiq tests.
SUMMARY_TEST_CLICKHOUSE_HTTP_URL=http://localhost:8123
SUMMARY_TEST_BROKER_URL=redis://localhost:6379/0
