# Core runtime
CONTROL_PLANE_TEST_MODE=true
CONTROL_PLANE_PROCESS_ALERTS=true
CONTROL_PLANE_LOG_LEVEL=DEBUG
CONTROL_PLANE_ALERT_CALLABLE=my_alert.send_sre_alert

# Data windows
CONTROL_PLANE_DATA_LOOKBACK_MINUTES=60
CONTROL_PLANE_PREDICTION_LOOKAHEAD_MINUTES=60
CONTROL_PLANE_LOOPBACK_MINUTES=30
CONTROL_PLANE_ANALYZE_TOP_N_ANOMALIES=2

# Actual metrics source: prometheus | clickhouse
CONTROL_PLANE_METRICS_SOURCE=clickhouse

# ClickHouse actual metrics source
# Here should be a full query for source metrics.
# Current mode: read all available points (no timestamp WHERE filter).
CONTROL_PLANE_CLICKHOUSE_METRICS_HOST=localhost
CONTROL_PLANE_CLICKHOUSE_METRICS_PORT=8123
CONTROL_PLANE_CLICKHOUSE_METRICS_USERNAME=
CONTROL_PLANE_CLICKHOUSE_METRICS_PASSWORD=
CONTROL_PLANE_CLICKHOUSE_METRICS_SECURE=false
CONTROL_PLANE_CLICKHOUSE_METRICS_QUERY=SELECT timestamp, value FROM metrics_table ORDER BY timestamp

# Logs source for batched summarization (one full SQL query string)
CONTROL_PLANE_LOGS_CLICKHOUSE_HOST=localhost
CONTROL_PLANE_LOGS_CLICKHOUSE_PORT=8123
CONTROL_PLANE_LOGS_CLICKHOUSE_USERNAME=
CONTROL_PLANE_LOGS_CLICKHOUSE_PASSWORD=
CONTROL_PLANE_CLICKHOUSE_LOGS_QUERY=SELECT timestamp, value FROM logs_demo_service WHERE timestamp >= parseDateTimeBestEffort('{period_start}') AND timestamp < parseDateTimeBestEffort('{period_end}') ORDER BY timestamp LIMIT {limit} OFFSET {offset}
CONTROL_PLANE_LOGS_PAGE_LIMIT=1000
CONTROL_PLANE_LOGS_FETCH_MODE=time_window
CONTROL_PLANE_LOGS_TAIL_LIMIT=1000
CONTROL_PLANE_UI_LOGS_SUMMARY_DEFAULT_SQL=SELECT timestamp, level, message, container, pod, node, cluster FROM logs_demo_service WHERE timestamp >= parseDateTimeBestEffort('{period_start}') AND timestamp < parseDateTimeBestEffort('{period_end}') ORDER BY timestamp LIMIT {limit} OFFSET {offset}
CONTROL_PLANE_UI_LOGS_SUMMARY_DEFAULT_METRICS_SQL=
CONTROL_PLANE_UI_LOGS_SUMMARY_BATCH_SIZE=200
CONTROL_PLANE_UI_LOGS_SUMMARY_DB_BATCH_SIZE=1000
CONTROL_PLANE_UI_LOGS_SUMMARY_LLM_BATCH_SIZE=200

# Prometheus
CONTROL_PLANE_PROM_METRICS_URL=http://localhost:9090
CONTROL_PLANE_PROM_METRICS_USERNAME=test-user
CONTROL_PLANE_PROM_METRICS_PASSWORD=test-password
CONTROL_PLANE_PROM_METRICS_DISABLE_SSL=true
CONTROL_PLANE_PROM_METRICS_QUERY=sum(container_memory_working_set_bytes{image!="", container="", node=""})
CONTROL_PLANE_PROM_METRICS_STEP=1m
CONTROL_PLANE_PROM_METRICS_MAX_POINTS=11000
CONTROL_PLANE_PROM_METRICS_SERIES_INDEX=0

# Forecast source
CONTROL_PLANE_CLICKHOUSE_PREDICTIONS_HOST=localhost
CONTROL_PLANE_CLICKHOUSE_PREDICTIONS_PORT=8123
CONTROL_PLANE_CLICKHOUSE_PREDICTIONS_USERNAME=
CONTROL_PLANE_CLICKHOUSE_PREDICTIONS_PASSWORD=
CONTROL_PLANE_CLICKHOUSE_PREDICTIONS_SECURE=false
CONTROL_PLANE_CLICKHOUSE_PREDICTIONS_QUERY=SELECT timestamp, value AS predicted FROM metrics_forecast WHERE service='{service}' AND metric_name='{metric_name}' AND generated_at = (SELECT max(generated_at) FROM metrics_forecast WHERE service='{service}' AND metric_name='{metric_name}') AND timestamp > now() ORDER BY timestamp
CONTROL_PLANE_FORECAST_SERVICE=demo-service
CONTROL_PLANE_FORECAST_METRIC_NAME=memory
CONTROL_PLANE_FORECAST_TYPE=short
CONTROL_PLANE_PREDICTION_KIND=forecast

# Anomaly detector
# Options: rolling_iqr | residual_zscore | pyod_ecod | pyod_iforest | ruptures_pelt
CONTROL_PLANE_ANOMALY_DETECTOR=pyod_iforest
CONTROL_PLANE_ANOMALY_IQR_WINDOW=60
CONTROL_PLANE_ANOMALY_IQR_SCALE=1.5
CONTROL_PLANE_ANOMALY_IQR_MIN_PERIODS=30
CONTROL_PLANE_ANOMALY_ZSCORE=3.0
CONTROL_PLANE_ANOMALY_PYOD_CONTAMINATION=0.05
CONTROL_PLANE_ANOMALY_PYOD_RANDOM_STATE=42
CONTROL_PLANE_ANOMALY_RUPTURES_PENALTY=8.0
CONTROL_PLANE_ANOMALY_RUPTURES_MODEL=rbf

# Test-mode synthetic generator
CONTROL_PLANE_TEST_SEED=42
CONTROL_PLANE_TEST_SPIKE_RATE=0.03
CONTROL_PLANE_TEST_SPIKE_SCALE=12.0
CONTROL_PLANE_TEST_NOISE_SCALE=1.5
CONTROL_PLANE_TEST_SUMMARY_BATCHES=4
CONTROL_PLANE_TEST_LOGS_PER_BATCH=120
