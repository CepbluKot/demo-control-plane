# Core runtime
CONTROL_PLANE_TEST_MODE=true
CONTROL_PLANE_PROCESS_ALERTS=true
CONTROL_PLANE_LOG_LEVEL=DEBUG

# Data windows
CONTROL_PLANE_DATA_LOOKBACK_MINUTES=60
CONTROL_PLANE_PREDICTION_LOOKAHEAD_MINUTES=60
CONTROL_PLANE_LOOPBACK_MINUTES=30
CONTROL_PLANE_ANALYZE_TOP_N_ANOMALIES=2

# Prometheus
CONTROL_PLANE_PROM_URL=http://localhost:9090
CONTROL_PLANE_PROM_USERNAME=test-user
CONTROL_PLANE_PROM_PASSWORD=test-password
CONTROL_PLANE_PROM_DISABLE_SSL=true
CONTROL_PLANE_PROM_QUERY=sum(container_memory_working_set_bytes{image!="", container="", node=""})
CONTROL_PLANE_PROM_STEP=1m
CONTROL_PLANE_PROM_MAX_POINTS=11000
CONTROL_PLANE_PROM_SERIES_INDEX=0

# Forecast source
CONTROL_PLANE_FORECAST_SERVICE=demo-service
CONTROL_PLANE_FORECAST_METRIC_NAME=memory
CONTROL_PLANE_FORECAST_TYPE=short
CONTROL_PLANE_PREDICTION_KIND=forecast

# Anomaly detector
CONTROL_PLANE_ANOMALY_DETECTOR=rolling_iqr
CONTROL_PLANE_ANOMALY_IQR_WINDOW=60
CONTROL_PLANE_ANOMALY_IQR_SCALE=1.5
CONTROL_PLANE_ANOMALY_IQR_MIN_PERIODS=30
CONTROL_PLANE_ANOMALY_ZSCORE=3.5

# Test-mode synthetic generator
CONTROL_PLANE_TEST_SEED=42
CONTROL_PLANE_TEST_SPIKE_RATE=0.03
CONTROL_PLANE_TEST_SPIKE_SCALE=12.0
CONTROL_PLANE_TEST_NOISE_SCALE=1.5
