# Core runtime
CONTROL_PLANE_TEST_MODE=true
CONTROL_PLANE_PROCESS_ALERTS=true
CONTROL_PLANE_LOG_LEVEL=DEBUG

# Data windows
CONTROL_PLANE_DATA_LOOKBACK_MINUTES=60
CONTROL_PLANE_PREDICTION_LOOKAHEAD_MINUTES=60
CONTROL_PLANE_LOOPBACK_MINUTES=30
CONTROL_PLANE_ANALYZE_TOP_N_ANOMALIES=1

# Actual metrics source: prometheus | clickhouse
CONTROL_PLANE_METRICS_SOURCE=prometheus

# Prometheus
CONTROL_PLANE_PROM_URL=http://localhost:9090
CONTROL_PLANE_PROM_USERNAME=test-user
CONTROL_PLANE_PROM_PASSWORD=test-password
CONTROL_PLANE_PROM_DISABLE_SSL=true
CONTROL_PLANE_PROM_QUERY=sum(container_memory_working_set_bytes{image!="", container="airflow-worker", node="ndp-v01wnl-n19"})
CONTROL_PLANE_PROM_STEP=1m
CONTROL_PLANE_PROM_MAX_POINTS=11000
CONTROL_PLANE_PROM_SERIES_INDEX=0

# ClickHouse actual metrics source (used when CONTROL_PLANE_METRICS_SOURCE=clickhouse)
# Рекомендуемый формат: только SELECT ... FROM ...
# WHERE по времени, ORDER BY и LIMIT добавляются автоматически.
# (Старый full-query с {start}/{end} тоже поддержан для backward compatibility)
CONTROL_PLANE_CLICKHOUSE_HOST=localhost
CONTROL_PLANE_CLICKHOUSE_PORT=8123
CONTROL_PLANE_CLICKHOUSE_USERNAME=
CONTROL_PLANE_CLICKHOUSE_PASSWORD=
CONTROL_PLANE_CLICKHOUSE_DATABASE=default
CONTROL_PLANE_CLICKHOUSE_SECURE=false
CONTROL_PLANE_CLICKHOUSE_QUERY=SELECT timestamp, value FROM metrics_table
CONTROL_PLANE_CLICKHOUSE_TIMESTAMP_COLUMN=timestamp
CONTROL_PLANE_CLICKHOUSE_VALUE_COLUMN=value
CONTROL_PLANE_CLICKHOUSE_TIMESTAMP_UNIT=
CONTROL_PLANE_CLICKHOUSE_VALUE_SCALE=1.0

# sqlalchemy_stuff / predictions DB credentials (used by sqlalchemy_stuff.engine)
TGT_DATABASE_HOST=localhost
TGT_DATABASE_PORT=8123
TGT_DATABASE_USERNAME=
TGT_DATABASE_PASSWORD=
METRICS_PREDICTIONS_DATABASE=default

# LLM credentials (for external summarizer integration)
OPENAI_API_BASE_DB=
OPENAI_API_KEY_DB=
LLM_MODEL_ID=PNX.QWEN3 235b a22b instruct

# Forecast source
CONTROL_PLANE_FORECAST_SERVICE=demo-service
CONTROL_PLANE_FORECAST_METRIC_NAME=memory
CONTROL_PLANE_FORECAST_TYPE=short
CONTROL_PLANE_PREDICTION_KIND=forecast

# Anomaly detector
CONTROL_PLANE_ANOMALY_DETECTOR=rolling_iqr
CONTROL_PLANE_ANOMALY_IQR_WINDOW=60
CONTROL_PLANE_ANOMALY_IQR_SCALE=1.5
CONTROL_PLANE_ANOMALY_IQR_MIN_PERIODS=30
CONTROL_PLANE_ANOMALY_ZSCORE=3.5

# Test-mode synthetic generator
CONTROL_PLANE_TEST_SEED=42
CONTROL_PLANE_TEST_SPIKE_RATE=0.03
CONTROL_PLANE_TEST_SPIKE_SCALE=12.0
CONTROL_PLANE_TEST_NOISE_SCALE=1.5

# Optional adapters (dotted path or module:path)
# CONTROL_PLANE_SUMMARIZER_CALLABLE=my_summarizer.summarize_logs
# CONTROL_PLANE_ALERT_CALLABLE=my_alert.send_sre_alert
