# Summary backend API
SUMMARY_BACKEND_API_HOST=0.0.0.0
SUMMARY_BACKEND_API_PORT=8088
SUMMARY_BACKEND_CORS_ORIGINS=http://localhost:8090,http://127.0.0.1:8090
SUMMARY_BACKEND_WEBSOCKET_POLL_INTERVAL_SECONDS=0.5

# Runtime logging and artifacts
SUMMARY_BACKEND_LOG_LEVEL=INFO
SUMMARY_BACKEND_LOG_DIR=artifacts/summary_backend/logs
SUMMARY_BACKEND_AUDIT_DIR=artifacts/summary_backend/audit
SUMMARY_BACKEND_UPLOAD_STAGING_DIR=artifacts/summary_backend/uploads

# Internal ClickHouse storage for jobs, events, nodes, artifacts and input segments
SUMMARY_BACKEND_CLICKHOUSE_HOST=localhost
SUMMARY_BACKEND_CLICKHOUSE_PORT=8123
SUMMARY_BACKEND_CLICKHOUSE_USERNAME=default
SUMMARY_BACKEND_CLICKHOUSE_PASSWORD=
SUMMARY_BACKEND_CLICKHOUSE_DATABASE=summary_test
SUMMARY_BACKEND_CLICKHOUSE_SECURE=false

# Optional source ClickHouse for user SQL inputs.
# Defaults to the internal ClickHouse settings when omitted.
SUMMARY_BACKEND_SOURCE_CLICKHOUSE_HOST=localhost
SUMMARY_BACKEND_SOURCE_CLICKHOUSE_PORT=8123
SUMMARY_BACKEND_SOURCE_CLICKHOUSE_USERNAME=default
SUMMARY_BACKEND_SOURCE_CLICKHOUSE_PASSWORD=
SUMMARY_BACKEND_SOURCE_CLICKHOUSE_DATABASE=summary_test
SUMMARY_BACKEND_SOURCE_CLICKHOUSE_SECURE=false

# Dramatiq broker
SUMMARY_BACKEND_BROKER_URL=redis://localhost:6379/0

# LLM provider. If values are empty, backend falls back to
# summary_backend/llm_gateway_defaults.json. Use SUMMARY_BACKEND_DRY_RUN=true
# to disable real LLM calls.
SUMMARY_BACKEND_OPENAI_API_BASE=
SUMMARY_BACKEND_OPENAI_API_KEY=
SUMMARY_BACKEND_LLM_MODEL=
SUMMARY_BACKEND_LLM_MODELS=llmgateway/free
SUMMARY_BACKEND_LLM_PROFILES=
SUMMARY_BACKEND_LLM_PROFILE_DEFAULT=
# Example:
# SUMMARY_BACKEND_LLM_PROFILES=gateway,openai
# SUMMARY_BACKEND_LLM_PROFILE_DEFAULT=gateway
# SUMMARY_BACKEND_LLM_PROFILE__GATEWAY__LABEL=LLM Gateway
# SUMMARY_BACKEND_LLM_PROFILE__GATEWAY__API_BASE=http://llm-gateway.example/v1
# SUMMARY_BACKEND_LLM_PROFILE__GATEWAY__API_KEY=
# SUMMARY_BACKEND_LLM_PROFILE__GATEWAY__DEFAULT_MODEL=llmgateway/free
# SUMMARY_BACKEND_LLM_PROFILE__GATEWAY__AVAILABLE_MODELS=llmgateway/free,llmgateway/analysis
# SUMMARY_BACKEND_LLM_PROFILE__OPENAI__LABEL=OpenAI
# SUMMARY_BACKEND_LLM_PROFILE__OPENAI__API_BASE=https://api.openai.com/v1
# SUMMARY_BACKEND_LLM_PROFILE__OPENAI__API_KEY=
# SUMMARY_BACKEND_LLM_PROFILE__OPENAI__DEFAULT_MODEL=gpt-4.1-mini
# SUMMARY_BACKEND_LLM_PROFILE__OPENAI__AVAILABLE_MODELS=gpt-4.1-mini,gpt-4.1
SUMMARY_BACKEND_LLM_TIMEOUT_SECONDS=600
SUMMARY_BACKEND_LLM_MAX_RETRIES=3
SUMMARY_BACKEND_LLM_RETRY_BACKOFF_SECONDS=2
# Global cap on concurrent outbound LLM calls across ALL jobs (Redis-backed pool).
SUMMARY_BACKEND_LLM_MAX_CONCURRENCY=5
SUMMARY_BACKEND_DRY_RUN=

# Pipeline sizing
SUMMARY_BACKEND_CHUNK_TARGET_ESTIMATED_TOKENS=6000
SUMMARY_BACKEND_REDUCE_GROUP_SIZE=8
SUMMARY_BACKEND_MAX_ENQUEUE_NODES_PER_ADVANCE=500

# Summary frontend
SUMMARY_FRONTEND_HOST=0.0.0.0
SUMMARY_FRONTEND_PORT=8090
SUMMARY_FRONTEND_BACKEND_HTTP_URL=http://localhost:8088
SUMMARY_FRONTEND_BACKEND_WS_URL=ws://localhost:8088
