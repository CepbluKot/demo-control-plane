# ── ClickHouse source ─────────────────────────────────────────────────
CH_HOST=localhost
CH_PORT=8123
CH_USER=default
CH_PASSWORD=
CH_DATABASE=default

# ── ClickHouse results ────────────────────────────────────────────────
RESULT_DATABASE=default
SAVE_TO_CH=false
AIRFLOW_RUN_ID=

# ── LLM ──────────────────────────────────────────────────────────────
API_BASE=http://localhost:8000
API_KEY=sk-placeholder
MODEL=qwen2.5-72b-instruct
MAX_CONTEXT_TOKENS=150000
MODEL_SUPPORTS_TOOL_CALLING=false

# Старые имена LLM_API_BASE / LLM_API_KEY / LLM_MODEL /
# LLM_CONTEXT_TOKENS / LLM_TOOL_CALLING тоже поддерживаются.

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=/tmp/pipeline.log
