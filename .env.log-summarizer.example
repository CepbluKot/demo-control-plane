# ── ClickHouse source ─────────────────────────────────────────────────
CH_HOST=localhost
CH_PORT=8123
CH_USER=default
CH_PASSWORD=
CH_DATABASE=default

# ── ClickHouse results ────────────────────────────────────────────────
RESULT_DATABASE=default
SAVE_TO_CH=false
AIRFLOW_RUN_ID=

# ── LLM ──────────────────────────────────────────────────────────────
LLM_API_BASE=http://localhost:8000
LLM_API_KEY=sk-placeholder
LLM_MODEL=qwen2.5-72b-instruct
LLM_CONTEXT_TOKENS=150000
LLM_TOOL_CALLING=false

# ── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_FILE=/tmp/pipeline.log
